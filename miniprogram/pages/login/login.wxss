/* pages/login/login.wxss */
.login-container {
  min-height: 100vh;
  background: linear-gradient(to bottom, #dbeafe, #ffffff);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32px 16px;
  box-sizing: border-box;
}

.login-card {
  width: 100%;
  max-width: 400px;
  background: #ffffff;
  border-radius: 24px;
  padding: 48px 32px;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48px;
}

.logo-icon {
  width: 80px;
  height: 80px;
  background: #dbeafe;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20px;
}

.logo-image {
  width: 48px;
  height: 48px;
}

.app-title {
  font-size: 26px;
  font-weight: 700;
  color: #111827;
  margin-bottom: 8px;
}

.app-subtitle {
  font-size: 14px;
  color: #6b7280;
}

.login-info {
  text-align: center;
  margin-bottom: 40px;
}

.info-text {
  font-size: 14px;
  color: #4b5563;
  line-height: 1.6;
}

.wechat-login-btn {
  width: 100%;
  height: 52px;
  background: #16a34a;
  border-radius: 12px;
  border: none;
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
}

.wechat-login-btn::after {
  border: none;
}

.wechat-login-btn:active {
  background: #15803d;
}

.wechat-login-btn.btn-loading {
  opacity: 0.7;
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
}

.wechat-icon {
  width: 22px;
  height: 22px;
}

.loading-spinner {
  width: 20px;
  height: 20px;
  border: 2px solid transparent;
  border-top-color: #ffffff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.btn-text {
  font-size: 16px;
  font-weight: 500;
  color: #ffffff;
}

.dev-hint {
  text-align: center;
  margin-top: 24px;
}

.hint-text {
  font-size: 12px;
  color: #9ca3af;
}
